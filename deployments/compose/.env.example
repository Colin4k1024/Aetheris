# Aetheris Docker Compose — 环境变量示例
# 使用方法：
#   cp .env.example .env
#   vim .env        # 至少填写 API_MIDDLEWARE_JWT_KEY
#   docker compose up -d

# ─── 必填 ────────────────────────────────────────────────────────────────────

# JWT 签名密钥（任意随机字符串，生成方法：openssl rand -hex 32）
API_MIDDLEWARE_JWT_KEY=change-me-to-a-random-secret

# ─── LLM 配置（二选一）────────────────────────────────────────────────────────

# 方案 A：使用 Ollama（本地模型，免费）
#   前提：需先在宿主机运行 `ollama serve` 并拉取模型
#   OLLAMA_MODEL=llama3:latest

# 方案 B：使用 OpenAI / 兼容 API
#   在 docker-compose.yml 中将 MODEL_LLM_PROVIDERS_OPENAI_API_KEY 和 BASE_URL 改为真实值

# ─── 可选覆盖 ─────────────────────────────────────────────────────────────────

# Ollama 模型名（默认 llama3:latest）
# OLLAMA_MODEL=llama3:latest

# Planner 类型（rule = 规则引擎，llm = LLM 驱动规划）
# PLANNER_TYPE=rule
