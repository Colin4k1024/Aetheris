{
  // CoRag Agent Snippets for Go
  "corag-import": {
    "prefix": "corag-import",
    "body": [
      "import (",
      "\\t\"context\"",
      "\\t\"fmt\"",
      "",
      "\\t\"github.com/Colin4k1024/Aetheris/v2/internal/runtime/eino\"",
      "\\t\"github.com/cloudwego/eino/adk\"",
      ")"
    ],
    "description": "Import CoRag and Eino packages"
  },
  "corag-agent-config": {
    "prefix": "corag-agent-config",
    "body": [
      "// ${1:AgentName}Config holds configuration for the ${1:AgentName} agent",
      "type ${1:AgentName}Config struct {",
      "\\tName        string",
      "\\tDescription string",
      "\\tMaxSteps    int",
      "\\tTools       []string",
      "}"
    ],
    "description": "Define agent configuration struct"
  },
  "corag-new-agent": {
    "prefix": "corag-new-agent",
    "body": [
      "// New${1:AgentName}Agent creates a new ${1:AgentName} agent",
      "func New${1:AgentName}Agent(ctx context.Context) (*adk.Runner, error) {",
      "\\t// Create ChatModel",
      "\\tchatModel, err := openai.NewChatModel(ctx, &openai.ChatModelConfig{",
      "\\t\\tModel:  os.Getenv(\"LLM_MODEL\"),",
      "\\t\\tAPIKey: os.Getenv(\"OPENAI_API_KEY\"),",
      "\\t})",
      "\\tif err != nil {",
      "\\t\\treturn nil, fmt.Errorf(\"failed to create chat model: %w\", err)",
      "\\t}",
      "",
      "\\t// Build agent config",
      "\\tagentCfg := &eino.AgentBuildConfig{",
      "\\t\\tName:        \"${1:agent-name}\",",
      "\\t\\tDescription: \"${2:agent description}\",",
      "\\t\\tType:        \"${3:react}\",",
      "\\t\\tMaxSteps:    ${4:10},",
      "\\t\\tStreaming:   ${5:true},",
      "\\t}",
      "",
      "\\t// Create agent via AgentFactory",
      "\\tfactory := eino.NewAgentFactory(nil, nil)",
      "\\trunner, err := factory.CreateAgent(ctx, *agentCfg)",
      "\\tif err != nil {",
      "\\t\\treturn nil, fmt.Errorf(\"failed to create agent: %w\", err)",
      "\\t}",
      "",
      "\\treturn runner, nil",
      "}"
    ],
    "description": "Create new CoRag agent with AgentFactory"
  },
  "corag-runner-query": {
    "prefix": "corag-runner-query",
    "body": [
      "// Run the agent",
      "iter := runner.Query(ctx, \"$1\")",
      "",
      "for {",
      "\\tevent, ok := iter.Next()",
      "\\tif !ok {",
      "\\t\\tbreak",
      "\\t}",
      "\\tif event.Err != nil {",
      "\\t\\tfmt.Fprintf(os.Stderr, \"Error: %v\\n\", event.Err)",
      "\\t\\tcontinue",
      "\\t}",
      "\\tif event.Output != nil && event.Output.MessageOutput != nil {",
      "\\t\\tmsg := event.Output.MessageOutput.Message",
      "\\t\\tif msg != nil && msg.Content != \"\" {",
      "\\t\\t\\tfmt.Printf(\"Response: %s\\n\", msg.Content)",
      "\\t\\t}",
      "\\t}",
      "}"
    ],
    "description": "Run agent with Query and handle events"
  },
  "corag-run-with-session": {
    "prefix": "corag-run-with-session",
    "body": [
      "// Run with session for stateful conversation",
      "sess := session.New(sessionID)",
      "sess.AddMessage(\"user\", userQuery)",
      "",
      "result, err := agent.RunWithSession(ctx, sess, userQuery)",
      "if err != nil {",
      "\\treturn nil, fmt.Errorf(\"run with session failed: %w\", err)",
      "}",
      "",
      "fmt.Printf(\"Answer: %s\\n\", result.Answer)",
      "fmt.Printf(\"Steps: %d\\n\", result.Steps)",
      "fmt.Printf(\"Duration: %v\\n\", result.Duration)"
    ],
    "description": "Run agent with session for stateful execution"
  },
  "corag-checkpoint": {
    "prefix": "corag-checkpoint",
    "body": [
      "// Create agent with checkpoint support",
      "checkpointStore := NewMemoryCheckPointStore()",
      "",
      "runner, err := factory.CreateAgentWithCheckpoint(ctx, agentCfg, checkpointStore)",
      "if err != nil {",
      "\\treturn nil, fmt.Errorf(\"failed to create agent with checkpoint: %w\", err)",
      "}"
    ],
    "description": "Create agent with checkpoint support for durability"
  },
  "corag-human-approval": {
    "prefix": "corag-human-approval",
    "body": [
      "// Define human approval workflow",
      "&planner.TaskGraph{",
      "\\tNodes: []planner.TaskNode{",
      "\\t\\t{",
      "\\t\\t\\tID:   \"${1:analyze}\",",
      "\\t\\t\\tType: planner.NodeLLM,",
      "\\t\\t\\tConfig: map[string]any{",
      "\\t\\t\\t\\t\"prompt\": \"$2\",",
      "\\t\\t\\t},",
      "\\t\\t},",
      "\\t\\t{",
      "\\t\\t\\tID:   \"${3:approval}\",",
      "\\t\\t\\tType: planner.NodeWait,",
      "\\t\\t\\tConfig: map[string]any{",
      "\\t\\t\\t\\t\"wait_kind\":       \"signal\",",
      "\\t\\t\\t\\t\"correlation_key\": \"${4:approval-key}\",",
      "\\t\\t\\t\\t\"timeout\":         \"${5:24h}\",",
      "\\t\\t\\t},",
      "\\t\\t},",
      "\\t\\t{",
      "\\t\\t\\tID:   \"${6:execute}\",",
      "\\t\\t\\tType: planner.NodeTool,",
      "\\t\\t\\tConfig: map[string]any{",
      "\\t\\t\\t\\t\"tool_name\": \"${7:process_tool}\",",
      "\\t\\t\\t},",
      "\\t\\t},",
      "\\t},",
      "\\tEdges: []planner.TaskEdge{",
      "\\t\\t{From: \"${1:analyze}\", To: \"${3:approval}\"},",
      "\\t\\t{From: \"${3:approval}\", To: \"${6:execute}\"},",
      "\\t},",
      "}"
    ],
    "description": "Define human approval workflow with NodeWait"
  },
  "corag-job-status": {
    "prefix": "corag-job-status",
    "body": [
      "import \"github.com/Colin4k1024/Aetheris/v2/internal/agent/job\"",
      "",
      "// Job status constants",
      "// job.StatusPending, job.StatusRunning, job.StatusCompleted,",
      "// job.StatusFailed, job.StatusCancelled, job.StatusWaiting,",
      "// job.StatusParked, job.StatusRetrying",
      "",
      "// Check job status",
      "switch job.Status {",
      "case job.StatusPending:",
      "\\tfmt.Println(\"Job is pending\")",
      "case job.StatusRunning:",
      "\\tfmt.Println(\"Job is running\")",
      "case job.StatusCompleted:",
      "\\tfmt.Println(\"Job completed successfully\")",
      "case job.StatusFailed:",
      "\\tfmt.Println(\"Job failed\")",
      "case job.StatusWaiting:",
      "\\tfmt.Println(\"Job is waiting for signal\")",
      "case job.StatusParked:",
      "\\tfmt.Println(\"Job is parked (long wait)\")",
      "default:",
      "\\tfmt.Printf(\"Unknown status: %v\\n\", job.Status)",
      "}"
    ],
    "description": "Job status constants and handling"
  },
  "corag-runtime-event": {
    "prefix": "corag-runtime-event",
    "body": [
      "// RuntimeEvent types",
      "// eino.EventTypeRunCreated, eino.EventTypeRunPaused,",
      "// eino.EventTypeRunResumed, eino.EventTypeStepStarted,",
      "// eino.EventTypeStepCompleted, eino.EventTypeToolCallStarted,",
      "// eino.EventTypeToolCallEnded, eino.EventTypeRunFailed,",
      "// eino.EventTypeRunSucceeded, eino.EventTypeHumanInjected",
      "",
      "event := &eino.RuntimeEvent{",
      "\\tID:     \"evt-${1:001}\",",
      "\\tRunID:  runID,",
      "\\tType:   eino.EventType${2:RunCreated},",
      "\\tSeq:    ${3:1},",
      "\\tActor:  \"${4:system}\",",
      "\\tPayload: map[string]interface{}{",
      "\\t\\t\"${5:key}\": \"${6:value}\",",
      "\\t},",
      "\\tOccurredAt: time.Now(),",
      "}"
    ],
    "description": "Create runtime event for tracing"
  },
  "corag-workflow": {
    "prefix": "corag-workflow",
    "body": [
      "// Define a workflow using eino compose",
      "workflow := compose.NewGraph[*eino.Message, *eino.Message](",
      "",
      "// Add nodes",
      "compose.AddChatNode(\"start\", startNode),",
      "compose.AddChatNode(\"process\", processNode),",
      "compose.AddChatNode(\"end\", endNode),",
      "",
      "// Add edges",
      "compose.AddEdge(\"start\", \"process\"),",
      "compose.AddEdge(\"process\", \"end\"),",
      "",
      "// Compile",
      "compiled, err := workflow.Compile(ctx)",
      "if err != nil {",
      "\\treturn nil, fmt.Errorf(\"compile workflow failed: %w\", err)",
      "}"
    ],
    "description": "Define workflow using eino compose graph"
  },
  "corag-tool-bridge": {
    "prefix": "corag-tool-bridge",
    "body": [
      "// Create tool bridge to convert tools to Eino format",
      "bridge := eino.NewRegistryToolBridge(registry)",
      "",
      "// Get Eino-compatible tools",
      "einoTools := bridge.EinoTools()",
      "",
      "// Use tools in agent config",
      "agentCfg := &adk.ChatModelAgentConfig{",
      "\\tToolsConfig: adk.ToolsConfig{",
      "\\t\\tToolsNodeConfig: compose.ToolsNodeConfig{",
      "\\t\\t\\tTools: einoTools,",
      "\\t\\t},",
      "\\t},",
      "}"
    ],
    "description": "Use tool bridge to convert tools to Eino format"
  },
  "corag-trace-event": {
    "prefix": "corag-trace-event",
    "body": [
      "// Create trace event",
      "{",
      "\\tid:         \"evt-${1:001}\",",
      "\\trun_id:     \"${2:run-001}\",",
      "\\tstep_id:    \"${3:step-001}\",",
      "\\ttool_call_id: \"${4:tc-001}\",",
      "\\ttype:       \"${5:TOOL_CALL_STARTED}\",",
      "\\tseq:        ${6:1},",
      "\\tactor:      \"${7:agent}\",",
      "\\tpayload:    map[string]interface{}{",
      "\\t\\t\"tool_name\": \"${8:web_search}\",",
      "\\t\\t\"input\":     map[string]interface{}{",
      "\\t\\t\\t\"query\": \"${9:example}\",",
      "\\t\\t},",
      "\\t},",
      "\\toccurred_at: \"${10:2024-01-01T00:00:00Z}\",",
      "}"
    ],
    "description": "Create trace event for debugging"
  }
}
