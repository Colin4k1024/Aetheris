    </mxCell>

    <mxCell id="flow-db2" value="&lt;b&gt;租约写入&lt;/b&gt;&lt;br/&gt;INSERT job_claims (worker_id, attempt_id)&lt;br/&gt;UPDATE jobs SET status=Running" style=" rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=left;" vertex="1" parent="1">
