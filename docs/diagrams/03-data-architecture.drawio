    <!-- - DB writes for step 1 - -->
    <mxCell id="flow-db1" value="&lt;b&gt;双写创建&lt;/b&gt;&lt;br/&gt;INSERT jobs (status=Pending)&lt;br/&gt;INSERT job_events (type=JobCreated, version=1)" style=" rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=left;" vertex="1" parent="1">
