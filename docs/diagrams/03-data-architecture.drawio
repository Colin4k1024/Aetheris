    <!-- - Step 1: User submits goal - -->
    <mxCell id="flow-step1" value="① 用户提交目标（POST /api/agents/:id/message）" style=" rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
