    </mxCell>

    <!-- - Step 4: Runner executes steps - -->
    <mxCell id="flow-step4" value="④ Runner 逐节点执行（DAG Steppable）" style=" rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="860" y="345" width="380" height="45" as="geometry" />
    </mxCell>

    <mxCell id="flow-db4" value="&lt;b&gt;步骤事件追加&lt;/b&gt;&lt;br/&gt;INSERT job_events (type=StepStarted)&lt;br/&gt;INSERT job_events (type=StepCompleted)" style=" rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=left;" vertex="1" parent="1">
      <mxGeometry x="1280" y="335" width="260" height="65" as="geometry" />
    </mxCell>

    <mxCell id="arr3-4" style=" edgeStyle=orthogonalEdgeStyle;" edge="1" source="flow-step3" target="flow-step4" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <mxCell id="arr4" style=" edgeStyle=orthogonalEdgeStyle;" edge="1" source="flow-step4" target="flow-db4" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- - Step 5: Tool call (two-phase commit) - -->
    <mxCell id="flow-step5" value="⑤ Tool 调用（两步提交，at-most-once）" style=" rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="860" y="440" width="380" height="45" as="geometry" />
    </mxCell>

    <mxCell id="flow-db5" value="&lt;b&gt;两步提交写入&lt;/b&gt;&lt;br/&gt;① INSERT tool_invocations (status=started)&lt;br/&gt;② Execute Tool&lt;br/&gt;③ INSERT effects (kind=Tool, output)&lt;br/&gt;④ INSERT job_events (type=CommandCommitted)&lt;br/&gt;⑤ UPDATE tool_invocations SET committed=true" style=" rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=left;" vertex="1" parent="1">
      <mxGeometry x="1280" y="420" width="260" height="100" as="geometry" />
    </mxCell>

    <mxCell id="arr4-5" style=" edgeStyle=orthogonalEdgeStyle;" edge="1" source="flow-step4" target="flow-step5" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <mxCell id="arr5" style=" edgeStyle=orthogonalEdgeStyle;" edge="1" source="flow-step5" target="flow-db5" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- - Step 6: Checkpoint - -->
    <mxCell id="flow-step6" value="⑥ 定期写 Checkpoint（节点完成后）" style=" rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="860" y="535" width="380" height="45" as="geometry" />
    </mxCell>

    <mxCell id="flow-db6" value="&lt;b&gt;检查点持久化&lt;/b&gt;&lt;br/&gt;INSERT checkpoints (task_graph_state,&lt;br/&gt; memory_state, cursor_node)&lt;br/&gt;UPDATE jobs SET cursor=checkpoint_id" style=" rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;" vertex="1" parent="1">
      <mxGeometry x="1280" y="525" width="260" height="70" as="geometry" />
    </mxCell>

    <mxCell id="arr5-6" style=" edgeStyle=orthogonalEdgeStyle;" edge="1" source="flow-step5" target="flow-step6" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <mxCell id="arr6" style=" edgeStyle=orthogonalEdgeStyle;" edge="1" source="flow-step6" target="flow-db6" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- - Decision: crash? - -->
    <mxCell id="flow-decision-crash" value="崩溃？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="940" y="620" width="120" height="70" as="geometry" />
    </mxCell>

    <mxCell id="arr6-d" style=" edgeStyle=orthogonalEdgeStyle;" edge="1" source="flow-step6" target="flow-decision-crash" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- - Crash Recovery Path - -->
    <mxCell id="flow-recovery" value="⑦-A 崩溃恢复：加载最新 Checkpoint&lt;br/&gt;+ 重放后续 Events（不重执行已提交 Tool/LLM）" style=" rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="820" y="730" width="300" height="60" as="geometry" />
    </mxCell>

    <mxCell id="arr-crash-yes" value="YES" style=" edgeStyle=orthogonalEdgeStyle;strokeColor=#b85450;fontStyle=1;" edge="1" source="flow-decision-crash" target="flow-recovery" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <mxCell id="flow-recovery-db" value="&lt;b&gt;恢复读取&lt;/b&gt;&lt;br/&gt;SELECT checkpoints WHERE job_id=?&lt;br/&gt; ORDER BY created_at DESC LIMIT 1&lt;br/&gt;SELECT job_events WHERE version &gt; snapshot&lt;br/&gt;Inject results from effects table&lt;br/&gt;Resume from cursor_node" style=" rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=left;" vertex="1" parent="1">
      <mxGeometry x="820" y="815" width="300" height="100" as="geometry" />
    </mxCell>

    <mxCell id="arr-recovery" style=" edgeStyle=orthogonalEdgeStyle;" edge="1" source="flow-recovery" target="flow-recovery-db" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- - Normal completion - -->
    <mxCell id="flow-step7" value="⑦-B 正常完成" style=" rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="1160" y="625" width="200" height="45" as="geometry" />
    </mxCell>

    <mxCell id="arr-crash-no" value="NO" style=" edgeStyle=orthogonalEdgeStyle;strokeColor=#82b366;fontStyle=1;" edge="1" source="flow-decision-crash" target="flow-step7" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <mxCell id="flow-db7" value="&lt;b&gt;完成事件&lt;/b&gt;&lt;br/&gt;INSERT job_events (type=JobCompleted)&lt;br/&gt;UPDATE jobs SET status=Completed&lt;br/&gt;DELETE job_claims (释放租约)" style=" rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;" vertex="1" parent="1">
      <mxGeometry x="1280" y="615" width="260" height="70" as="geometry" />
    </mxCell>

    <mxCell id="arr7" style=" edgeStyle=orthogonalEdgeStyle;" edge="1" source="flow-step7" target="flow-db7" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- - Human-in-the-Loop Signal - -->
    <mxCell id="flow-signal-box" value="Human-in-the-Loop / Signal 路径" style="swimlane;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontStyle=1;startSize=28;" vertex="1" parent="1">
      <mxGeometry x="820" y="940" width="720" height="190" as="geometry" />
    </mxCell>

    <mxCell id="flow-signal1" value="Job 遇到 Wait 节点&lt;br/&gt;→ UPDATE jobs SET status=Parked&lt;br/&gt;→ INSERT waiting_info (correlation_key)" style=" rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="flow-signal-box">
      <mxGeometry x="20" y="45" width="200" height="70" as="geometry" />
    </mxCell>

    <mxCell id="flow-signal2" value="外部信号到达&lt;br/&gt;POST /api/jobs/:id/signal&lt;br/&gt;→ INSERT signal_inbox (correlation_key)&lt;br/&gt;→ UPDATE waiting_info.status" style=" rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="flow-signal-box">
      <mxGeometry x="255" y="45" width="200" height="70" as="geometry" />
    </mxCell>

    <mxCell id="flow-signal3" value="WakeupQueue 唤醒 Job&lt;br/&gt;→ UPDATE jobs SET status=Pending&lt;br/&gt;→ INSERT job_events (type=JobRunning)&lt;br/&gt;→ Scheduler 重新 Claim 继续执行" style=" rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="flow-signal-box">
      <mxGeometry x="490" y="45" width="210" height="70" as="geometry" />
    </mxCell>

    <mxCell id="arr-sig1-2" style=" edgeStyle=orthogonalEdgeStyle;" edge="1" source="flow-signal1" target="flow-signal2" parent="flow-signal-box">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <mxCell id="arr-sig2-3" style=" edgeStyle=orthogonalEdgeStyle;" edge="1" source="flow-signal2" target="flow-signal3" parent="flow-signal-box">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <mxCell id="signal-idempotent-note" value="幂等保证：相同 correlation_key 的重复 signal 为 no-op" style="text;html=1;fillColor=none;strokeColor=none;fontSize=10;fontStyle=2;" vertex="1" parent="flow-signal-box">
      <mxGeometry x="20" y="148" width="680" height="25" as="geometry" />
    </mxCell>

    <!-- - Event Sourcing pattern description - -->
    <mxCell id="es-pattern-box" value="事件溯源（Event Sourcing）模式说明" style="swimlane;fillColor=#fff9c4;strokeColor=#f9a825;fontSize=12;fontStyle=1;startSize=28;" vertex="1" parent="1">
      <mxGeometry x="1160" y="720" width="380" height="220" as="geometry" />
    </mxCell>

    <mxCell id="es-line1" value="• job_events 表是 &lt;b&gt;append-only 不可变日志&lt;/b&gt;" style="text;html=1;fillColor=none;strokeColor=none;fontSize=11;align=left;" vertex="1" parent="es-pattern-box">
      <mxGeometry x="10" y="38" width="360" height="22" as="geometry" />
    </mxCell>

    <mxCell id="es-line2" value="• 当前状态 = 从 v1 重放到最新 version" style="text;html=1;fillColor=none;strokeColor=none;fontSize=11;align=left;" vertex="1" parent="es-pattern-box">
      <mxGeometry x="10" y="60" width="360" height="22" as="geometry" />
    </mxCell>

    <mxCell id="es-line3" value="• Checkpoint = 重放性能优化（避免全量扫描）" style="text;html=1;fillColor=none;strokeColor=none;fontSize=11;align=left;" vertex="1" parent="es-pattern-box">
      <mxGeometry x="10" y="82" width="360" height="22" as="geometry" />
    </mxCell>

    <mxCell id="es-line4" value="• prev_hash + hash 链 = 防篡改 Proof Chain" style="text;html=1;fillColor=none;strokeColor=none;fontSize=11;align=left;" vertex="1" parent="es-pattern-box">
      <mxGeometry x="10" y="104" width="360" height="22" as="geometry" />
    </mxCell>

    <mxCell id="es-line5" value="• Replay 时：从 effects 注入结果，&lt;b&gt;不重执行&lt;/b&gt; LLM/Tool" style="text;html=1;fillColor=none;strokeColor=none;fontSize=11;align=left;" vertex="1" parent="es-pattern-box">
      <mxGeometry x="10" y="126" width="360" height="22" as="geometry" />
    </mxCell>

    <mxCell id="es-line6" value="• job_snapshots = 长跑 Job 的事件流 compaction" style="text;html=1;fillColor=none;strokeColor=none;fontSize=11;align=left;" vertex="1" parent="es-pattern-box">
      <mxGeometry x="10" y="148" width="360" height="22" as="geometry" />
    </mxCell>

    <mxCell id="es-line7" value="• attempt_id（lease fencing）防止 stale worker 写入" style="text;html=1;fillColor=none;strokeColor=none;fontSize=11;align=left;" vertex="1" parent="es-pattern-box">
      <mxGeometry x="10" y="170" width="360" height="22" as="geometry" />
    </mxCell>

    <!-- - Storage legend - -->
    <mxCell id="legend" value="图例" style="swimlane;fillColor=#f5f5f5;strokeColor=#999999;fontSize=12;fontStyle=1;startSize=25;" vertex="1" parent="1">
      <mxGeometry x="1160" y="960" width="380" height="165" as="geometry" />
    </mxCell>

    <mxCell id="leg1" value="jobs / agent_* 实体" style=" rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="legend">
      <mxGeometry x="10" y="35" width="155" height="28" as="geometry" />
    </mxCell>

    <mxCell id="leg2" value="job_events / snapshots（Event Log）" style=" rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="legend">
      <mxGeometry x="175" y="35" width="195" height="28" as="geometry" />
    </mxCell>

    <mxCell id="leg3" value="tool_invocations / effects（Ledger）" style=" rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="legend">
      <mxGeometry x="10" y="73" width="195" height="28" as="geometry" />
    </mxCell>

    <mxCell id="leg4" value="checkpoints / memory（State）" style=" rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="legend">
      <mxGeometry x="215" y="73" width="155" height="28" as="geometry" />
    </mxCell>

    <mxCell id="leg5" value="waiting / signal / messages（Coordination）" style=" rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="legend">
      <mxGeometry x="10" y="111" width="230" height="28" as="geometry" />
    </mxCell>

    <mxCell id="leg6" value="租约 / 多租户 / 审计" style=" rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=10;" vertex="1" parent="legend">
      <mxGeometry x="250" y="111" width="120" height="28" as="geometry" />
